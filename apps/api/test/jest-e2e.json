{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      { "tsconfig": "<rootDir>/../tsconfig.json" }
    ]
  },
  "moduleNameMapper": {
    "^@pmgt/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
    "^src/(.*)$": "<rootDir>/../src/$1"
  }
}
